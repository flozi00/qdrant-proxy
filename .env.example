# =============================================================================
# Qdrant Proxy - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.

# --- Qdrant Database ---
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=          # Optional: Qdrant API key if authentication is enabled
COLLECTION_NAME=documents  # Default collection name for document storage

# --- Embedding Models ---
DENSE_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B    # Dense embedding model name
DENSE_EMBEDDING_URL=http://vllm-embedding:9091/v1  # vLLM embedding server URL
DENSE_VECTOR_SIZE=1024                          # Must match model output dimension
COLBERT_MODEL_NAME=VAGOsolutions/SauerkrautLM-Multi-ModernColBERT  # PyLate ColBERT model
# TORCH_COMPILE=false      # Enable torch.compile for faster inference (requires PyTorch 2.0+)

# --- LLM Configuration (for fact extraction) ---
LITELLM_BASE_URL=http://localhost:4000/v1       # LiteLLM proxy URL
OPENAI_API_KEY=                                 # API key for LLM access
FACT_EXTRACTION_MODEL=default                   # Model name for fact extraction

# --- Fact Merge Settings ---
FACT_MERGE_ENABLED=true
# FACT_MERGE_MODEL=default
# FACT_MERGE_TOP_K=5
# FACT_MERGE_CANDIDATE_LIMIT=10
# FACT_MERGE_MIN_SEARCH_SCORE=0.5
# FACT_MERGE_MIN_RERANK_SCORE=1.5
# FACT_MERGE_MIN_LLM_CONFIDENCE=0.85
# FACT_MERGE_SKIP_CONTACT_FACTS=false
# FACT_AGENT_MAX_CONCURRENT=5

# --- Document Ingestion ---
MIN_CONTENT_WORDS=32       # Minimum word count to store a document

# --- Admin API ---
QDRANT_PROXY_ADMIN_KEY=    # Secret key for admin endpoints (leave empty to disable)

# --- Server ---
PORT=8000
LOG_LEVEL=warning          # debug, info, warning, error
